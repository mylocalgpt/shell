#!/bin/sh
set -e

echo "pre-push: typecheck"
pnpm typecheck

echo "pre-push: lint"
pnpm lint

echo "pre-push: test"
pnpm test

echo "pre-push: build"
pnpm build

echo "pre-push: verify no node imports in dist"
bash scripts/check-node-imports.sh

echo "pre-push: comparison tests"
pnpm test:comparison

echo "pre-push: all checks passed"
