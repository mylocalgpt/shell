{
  "name": "@mylocalgpt/shell",
  "version": "0.0.2",
  "type": "module",
  "description": "Virtual bash interpreter for AI agents. Pure TypeScript, zero dependencies.",
  "keywords": ["bash", "shell", "interpreter", "virtual", "sandbox", "agent", "ai", "jq"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mylocalgpt/shell.git"
  },
  "author": "Peter Etelej",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./jq": {
      "types": "./dist/jq/index.d.mts",
      "import": "./dist/jq/index.mjs",
      "require": "./dist/jq/index.cjs"
    },
    "./overlay": {
      "types": "./dist/overlay/index.d.mts",
      "import": "./dist/overlay/index.mjs",
      "require": "./dist/overlay/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE", "AGENTS.md", "THREAT_MODEL.md"],
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:all": "vitest run && smokepod verify --target node --target-arg scripts/smokepod-adapter.mjs --mode process --tests tests/comparison/ --fixtures tests/comparison/fixtures/ && biome check . && tsc --noEmit",
    "test:comparison": "smokepod verify --target node --target-arg scripts/smokepod-adapter.mjs --mode process --tests tests/comparison/ --fixtures tests/comparison/fixtures/",
    "test:record-fixtures": "smokepod record --target /bin/bash --tests tests/comparison/ --fixtures tests/comparison/fixtures/",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "bundle-size": "node scripts/check-bundle-size.mjs",
    "postversion": "biome check --write package.json && git add package.json && git commit --amend --no-edit"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^25.5.0",
    "smokepod": "^1.1.2",
    "tsdown": "^0.21.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  },
  "license": "Apache-2.0",
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild", "smokepod"]
  }
}
