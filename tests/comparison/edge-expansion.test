## brace-expansion-combos
$ echo {a,b}{1,2}
a1 a2 b1 b2

$ echo {a..c}{1..3}
a1 a2 a3 b1 b2 b3 c1 c2 c3

$ echo pre{A,B}post
preApost preBpost

$ echo {1..5}
1 2 3 4 5

$ echo {z..a}
z y x w v u t s r q p o n m l k j i h g f e d c b a

## glob-no-match
$ echo /nonexistent_path_xyz_*
/nonexistent_path_xyz_*

## arithmetic-in-strings
$ echo "result: $((2+2))"
result: 4

$ x=10; echo "double: $((x*2))"
double: 20

## arithmetic-command
$ x=0; ((x = 5)); echo $x
5

$ x=5; ((x++)); echo $x
6

$ if ((1)); then echo yes; fi
yes

$ if ((0)); then echo yes; else echo no; fi
no

## nested-default-expansion
$ unset a b c; echo "${a:-${b:-${c:-final}}}"
final

## null-command
$ : ; echo $?
0

## set-positional
$ set -- a b c; echo "$@"
a b c

$ set -- a b c; echo $#
3

$ set -- a b c; echo $2
b

## here-string
$ cat <<< "hello"
hello

## recursive-function
$ countdown() { if [ $1 -le 0 ]; then echo done; return; fi; echo $1; countdown $(($1 - 1)); }; countdown 3
3
2
1
done

## sed-transliterate
$ echo abc | sed 'y/abc/xyz/'
xyz

## sed-global-flag
$ echo "foo:bar:baz" | sed 's/:/ /g'
foo bar baz

