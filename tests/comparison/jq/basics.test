## basic-access
$ echo '{"name":"alice","age":30}' | jq '.name'
"alice"

$ echo '{"name":"alice","age":30}' | jq '.age'
30

$ echo '{"a":{"b":{"c":42}}}' | jq '.a.b.c'
42

## raw-output
$ echo '{"name":"alice"}' | jq -r '.name'
alice

$ echo '["a","b","c"]' | jq -r '.[]'
a
b
c

## array-ops
$ echo '[1,2,3]' | jq '.[0]'
1

$ echo '[1,2,3]' | jq '.[2]'
3

$ echo '[1,2,3]' | jq 'length'
3

## type-functions
$ echo '42' | jq 'type'
"number"

$ echo '"hello"' | jq 'type'
"string"

$ echo '[1,2]' | jq 'type'
"array"

$ echo '{"a":1}' | jq 'type'
"object"

$ echo 'null' | jq 'type'
"null"

$ echo 'true' | jq 'type'
"boolean"

## keys-and-values
$ echo '{"b":2,"a":1,"c":3}' | jq 'keys'
[
  "a",
  "b",
  "c"
]

## map-and-reduce
$ echo '[1,2,3,4,5]' | jq 'add'
15

## compact-output
$ echo '{"a": 1, "b": 2}' | jq -c '.'
{"a":1,"b":2}

## slicing
$ echo '[0,1,2,3,4]' | jq '.[1:3]'
[
  1,
  2
]

## has-and-in
$ echo '{"a":1,"b":2}' | jq 'has("a")'
true

$ echo '{"a":1,"b":2}' | jq 'has("c")'
false

## sort-and-group
$ echo '[3,1,2]' | jq 'sort'
[
  1,
  2,
  3
]

$ echo '["banana","apple","cherry"]' | jq 'sort'
[
  "apple",
  "banana",
  "cherry"
]

## flatten
$ echo '[[1,2],[3,[4,5]]]' | jq 'flatten'
[
  1,
  2,
  3,
  4,
  5
]

## tostring-tonumber
$ echo '42' | jq 'tostring'
"42"

$ echo '"42"' | jq 'tonumber'
42

## pipe-in-filter
$ echo '[1,2,3]' | jq '.[] | . * 2'
2
4
6

## alternative-operator
$ echo '{}' | jq '.b // "default"'
"default"

## map-arithmetic
$ echo '[1,2,3]' | jq 'map(. + 10)'
[
  11,
  12,
  13
]

## object-construction
$ echo '{"name":"alice"}' | jq '{name: .name}'
{
  "name": "alice"
}

## select-with-pipe
$ echo '[1,2,3,4,5]' | jq '[.[] | select(. > 3)]'
[
  4,
  5
]

## comma-multi-output
$ echo '{"a":1,"b":2}' | jq '.a, .b'
1
2

## del
$ echo '{"a":1,"b":2,"c":3}' | jq 'del(.b)'
{
  "a": 1,
  "c": 3
}

## identity
$ echo '42' | jq '.'
42

## array-iteration
$ echo '[1,2,3]' | jq '.[]'
1
2
3

## negative-index
$ echo '[1,2,3]' | jq '.[-1]'
3

## recursive-descent
$ echo '{"a":{"b":1},"c":2}' | jq '.. | numbers'
1
2

## string-interpolation
$ echo '{"name":"alice"}' | jq '"Hello, \(.name)!"'
"Hello, alice!"

## array-construction
$ echo '{"a":1,"b":2}' | jq '[.a, .b]'
[
  1,
  2
]

## arithmetic-ops
$ echo 'null' | jq '2 + 3'
5

$ echo 'null' | jq '10 - 3'
7

$ echo 'null' | jq '4 * 5'
20

$ echo 'null' | jq '10 / 3'
3.3333333333333335

## comparison-ops
$ echo 'null' | jq '5 > 3'
true

$ echo 'null' | jq '5 == 5'
true

$ echo 'null' | jq '5 != 3'
true

## logic-ops
$ echo 'null' | jq 'true and true'
true

$ echo 'null' | jq 'true and false'
false

$ echo 'null' | jq 'false or true'
true

$ echo 'null' | jq 'true | not'
false

## cli-slurp
$ echo -e '1\n2\n3' | jq -s '.'
[
  1,
  2,
  3
]

## cli-null-input
$ echo '' | jq -n '1 + 2'
3

## cli-sort-keys
$ echo '{"b":2,"a":1}' | jq -S '.'
{
  "a": 1,
  "b": 2
}

## cli-arg
$ echo 'null' | jq -n --arg name "alice" '$name'
"alice"
