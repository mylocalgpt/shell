## find-xargs-pattern
$ mkdir -p /tmp/tdir; touch /tmp/tdir/a.txt /tmp/tdir/b.log; find /tmp/tdir -name '*.txt' -type f
/tmp/tdir/a.txt

## find-type-directory
$ mkdir -p /tmp/fdir/sub; touch /tmp/fdir/file.txt; find /tmp/fdir -type d | sort
/tmp/fdir
/tmp/fdir/sub

## find-maxdepth
$ mkdir -p /tmp/fdir2/a/b; touch /tmp/fdir2/x.txt /tmp/fdir2/a/y.txt /tmp/fdir2/a/b/z.txt; find /tmp/fdir2 -maxdepth 1 -name '*.txt'
/tmp/fdir2/x.txt
