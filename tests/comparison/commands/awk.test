## awk-print-field
$ echo "hello world" | awk '{print $2}'
world

## awk-sum-field
$ printf "a 1\nb 2\nc 3\n" | awk '{sum += $2} END {print sum}'
6

## awk-begin-end
$ echo "" | awk 'BEGIN {print "start"} END {print "end"}'
start
end

## awk-field-separator
$ echo "a:b:c" | awk -F: '{print $2}'
b

$ echo "one,two,three" | awk -F, '{print $3}'
three

## awk-pattern-matching
$ printf "foo 1\nbar 2\nfoo 3\n" | awk '/foo/ {print $2}'
1
3

## awk-builtin-length
$ echo "hello" | awk '{print length($0)}'
5

## awk-builtin-substr
$ echo "hello world" | awk '{print substr($0, 7)}'
world

## awk-builtin-toupper
$ echo "hello" | awk '{print toupper($0)}'
HELLO

## awk-builtin-tolower
$ echo "HELLO" | awk '{print tolower($0)}'
hello

## awk-if-else
$ echo "5" | awk '{if ($1 > 3) print "big"; else print "small"}'
big

## awk-variables (xfail: awk post-increment not implemented)
$ printf "a\nb\nc\n" | awk '{count++} END {print count}'
3

## awk-string-concat
$ echo "hello" | awk '{print $0 " world"}'
hello world

## awk-ternary (xfail: awk ternary with string literals in print args)
$ echo "5" | awk '{print ($1 > 3 ? "yes" : "no")}'
yes

## awk-nr-nf
$ printf "a b\nc d e\n" | awk '{print NR, NF}'
1 2
2 3

## awk-ofs
$ echo "a b c" | awk 'BEGIN {OFS=","} {print $1, $2, $3}'
a,b,c
