## sed-basic
$ echo "hello world" | sed 's/world/earth/'
hello earth

$ echo "aaa" | sed 's/a/b/'
baa

$ echo "aaa" | sed 's/a/b/g'
bbb

## sed-delete
$ echo -e "a\nb\nc" | sed '2d'
a
c

$ echo -e "a\nb\nc" | sed '/b/d'
a
c

## sed-capture-groups
$ echo "hello world" | sed 's/\(hello\)/[\1]/'
[hello] world

## sed-advanced
$ echo -e "line1\nline2\nline3" | sed -n '2p'
line2

## sed-transliterate
$ echo abc | sed 'y/abc/xyz/'
xyz

## sed-global-flag
$ echo "foo:bar:baz" | sed 's/:/ /g'
foo bar baz

## sed-multiple-expressions
$ echo "hello world" | sed -e 's/hello/hi/' -e 's/world/earth/'
hi earth

## sed-address-ranges
$ echo -e "a\nb\nc\nd\ne" | sed '2,4d'
a
e

$ echo -e "a\nb\nc\nd\ne" | sed -n '2,4p'
b
c
d

## sed-print-line-number (xfail: sed = command not implemented)
$ echo -e "foo\nbar\nbaz" | sed -n '/bar/='
2
