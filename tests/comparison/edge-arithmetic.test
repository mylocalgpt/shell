## complex-expressions
$ echo $(( (5 + 3) * (10 - 4) ))
48

$ echo $(( 2 ** 8 - 1 ))
255

$ x=100; echo $(( x / 3 ))
33

$ echo $(( 7 % 3 + 2 * 5 ))
11

## chained-assignment
$ a=1; b=2; echo $(( a + b ))
3

$ echo $(( x = 5, y = 10, x + y ))
15

## ternary-complex
$ x=5; echo $(( x > 3 ? x * 2 : x + 1 ))
10

$ x=1; echo $(( x > 3 ? x * 2 : x + 1 ))
2

## negative-numbers
$ echo $(( -5 + 3 ))
-2

$ echo $(( -(-5) ))
5

$ echo $(( 0 - 100 ))
-100

## comparison-chains
$ echo $(( 5 > 3 && 10 > 7 ))
1

$ echo $(( 5 > 3 && 10 < 7 ))
0

$ echo $(( 5 > 3 || 10 < 7 ))
1

## modulo-edge-cases
$ echo $(( 10 % 3 ))
1

$ echo $(( -10 % 3 ))
-1

$ echo $(( 10 % -3 ))
1

## shift-operations
$ echo $(( 1 << 0 ))
1

$ echo $(( 1 << 8 ))
256

$ echo $(( 255 >> 4 ))
15

## arithmetic-in-conditionals
$ x=42; if [ $((x % 2)) -eq 0 ]; then echo even; else echo odd; fi
even

$ x=7; if [ $((x % 2)) -eq 0 ]; then echo even; else echo odd; fi
odd

## arithmetic-in-for
$ sum=0; for i in 1 2 3 4 5; do sum=$((sum + i)); done; echo $sum
15

$ fact=1; for i in $(seq 1 5); do fact=$((fact * i)); done; echo $fact
120

## declare-integer
$ declare -i num=5+3; echo $num
8

## function-positional-in-arithmetic
$ add() { echo $(($1 + $2)); }; add 3 4
7

## nested-arithmetic
$ x=3; y=4; echo $(( (x + y) * (x - y) ))
-7

$ a=2; b=3; c=4; echo $(( a * b + c ))
10

$ echo $(( 2 + 3 * 4 - 1 ))
13
