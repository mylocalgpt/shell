## assignment-and-echo
$ x=hello; echo $x
hello

$ x="hello world"; echo "$x"
hello world

$ x=hello; y=world; echo "$x $y"
hello world

## export-and-env
$ export FOO=bar; echo $FOO
bar

$ FOO=override echo ok
ok

## append
$ x=1; x+=2; echo $x
12

## unset
$ x=hello; unset x; echo ">${x}<"
><

## special-variables
$ echo $?
0

$ false; echo $?
1

$ true; echo $?
0

## parameter-expansion-default
$ echo ${UNSET_VAR:-default}
default

$ x=""; echo ${x:-default}
default

$ x=value; echo ${x:-default}
value

$ echo ${UNSET_VAR-default}
default

$ x=""; echo ${x-default}


## parameter-expansion-assign
$ echo ${newvar:=fallback}; echo $newvar
fallback
fallback

## parameter-expansion-alternate
$ x=set; echo ${x:+alternate}
alternate

$ echo ${UNSET_VAR:+alternate}


## parameter-expansion-length
$ x=hello; echo ${#x}
5

$ x=""; echo ${#x}
0

## parameter-expansion-substring
$ x=hello; echo ${x:1}
ello

$ x=hello; echo ${x:1:3}
ell

$ x=abcdef; echo ${x:0:3}
abc

## parameter-expansion-strip
$ x=hello.tar.gz; echo ${x%.gz}
hello.tar

$ x=/usr/local/bin; echo ${x#*/}
usr/local/bin

## parameter-expansion-replace
$ x="hello world hello"; echo ${x/hello/goodbye}
goodbye world hello

$ x="hello world hello"; echo ${x//hello/goodbye}
goodbye world goodbye

## declare-export
$ declare -x MYVAR=hello; echo $MYVAR
hello
