## if-basic
$ if true; then echo yes; fi
yes

$ if false; then echo yes; fi

$ if false; then echo yes; else echo no; fi
no

## if-elif
$ x=2; if [ "$x" = 1 ]; then echo one; elif [ "$x" = 2 ]; then echo two; else echo other; fi
two

## if-test-operators
$ if [ 5 -gt 3 ]; then echo yes; fi
yes

$ if [ 5 -lt 3 ]; then echo yes; else echo no; fi
no

$ if [ 5 -eq 5 ]; then echo equal; fi
equal

$ if [ -z "" ]; then echo empty; fi
empty

$ if [ -n "hello" ]; then echo nonempty; fi
nonempty

## if-double-bracket
$ if [[ "hello" == "hello" ]]; then echo match; fi
match

$ if [[ 10 -gt 5 ]] && [[ 3 -lt 7 ]]; then echo yes; fi
yes

## for-in-list
$ for x in a b c; do echo $x; done
a
b
c

$ for x in 1 2 3; do echo "num: $x"; done
num: 1
num: 2
num: 3

## for-brace-expansion
$ for i in {1..5}; do echo $i; done
1
2
3
4
5

$ for c in {a..e}; do echo $c; done
a
b
c
d
e

## for-c-style
$ for ((i=0; i<5; i++)); do echo $i; done
0
1
2
3
4

$ for ((i=10; i>0; i-=3)); do echo $i; done
10
7
4
1

## while-loop
$ i=0; while [ $i -lt 5 ]; do echo $i; i=$((i + 1)); done
0
1
2
3
4

## until-loop
$ i=0; until [ $i -ge 3 ]; do echo $i; i=$((i + 1)); done
0
1
2

## case-statement
$ x=hello; case $x in hello) echo matched;; world) echo no;; esac
matched

$ x=test; case $x in a*) echo a;; t*) echo t;; esac
t

$ x=yes; case $x in y|yes) echo affirm;; n|no) echo deny;; esac
affirm

## break-and-continue
$ for i in 1 2 3 4 5; do if [ $i -eq 3 ]; then break; fi; echo $i; done
1
2

$ for i in 1 2 3 4 5; do if [ $i -eq 3 ]; then continue; fi; echo $i; done
1
2
4
5

## nested-loops
$ for i in 1 2; do for j in a b; do echo "$i$j"; done; done
1a
1b
2a
2b

## functions
$ greet() { echo "hello $1"; }; greet world
hello world

$ counter() { local x=0; x=$((x+1)); echo $x; }; counter; counter
1
1
