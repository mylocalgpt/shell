## grep-regex
$ echo -e "abc\ndef\nabc123" | grep '^abc'
abc
abc123

$ echo -e "foo123\nbar456\nbaz" | grep '[0-9]'
foo123
bar456

$ echo -e "hello\nworld" | grep -c 'o'
1

$ echo "hello world" | grep -oE '[a-z]+'
hello
world

## sed-advanced
$ echo -e "line1\nline2\nline3" | sed -n '2p'
line2

## printf-edge-cases
$ printf '%s\n' a b c
a
b
c

$ printf '%x\n' 255
ff

$ printf '%o\n' 8
10

## set-noglob
$ set -f; echo *; set +f
*

## set-noclobber (xfail: noclobber works but stderr prefix differs from bash)
$ echo first > /tmp/noclobber_test; set -C; echo second > /tmp/noclobber_test 2>/dev/null; echo $?; cat /tmp/noclobber_test; set +C; rm -f /tmp/noclobber_test
1
first

## sort-advanced
$ echo -e "banana\napple\ncherry\napple" | sort -u
apple
banana
cherry

$ echo -e "10\n2\n1\n20" | sort -n
1
2
10
20

## cut-advanced
$ echo "2024-01-15" | cut -d- -f1
2024

$ echo "2024-01-15" | cut -d- -f2-
01-15

## find-xargs-pattern
$ mkdir -p /tmp/tdir; touch /tmp/tdir/a.txt /tmp/tdir/b.log; find /tmp/tdir -name '*.txt' -type f
/tmp/tdir/a.txt

## base64-roundtrip
$ echo -n "hello" | base64
aGVsbG8=

$ echo "aGVsbG8=" | base64 -d
hello

## checksum
$ echo -n "hello" | md5sum
5d41402abc4b2a76b9719d911017c592 (re)

$ echo -n "hello" | sha256sum
2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824 (re)

## wc-modes
$ echo -e "one two three\nfour five" | wc -w
(re)

$ echo -n "hello" | wc -c
(re)

## date-format
$ date +%Y-%m-%d
\d{4}-\d{2}-\d{2} (re)

## test-command
$ test 5 -gt 3 && echo yes
yes

$ test -z "" && echo empty
empty

$ test -n "hello" && echo nonempty
nonempty

$ [ "abc" = "abc" ] && echo equal
equal

$ [ "abc" != "def" ] && echo notequal
notequal
