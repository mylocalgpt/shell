## if-basic
$ if true; then echo yes; fi
yes

$ if false; then echo yes; fi

$ if false; then echo yes; else echo no; fi
no

## if-elif
$ x=2; if [ "$x" = 1 ]; then echo one; elif [ "$x" = 2 ]; then echo two; else echo other; fi
two

## if-test-operators
$ if [ 5 -gt 3 ]; then echo yes; fi
yes

$ if [ 5 -lt 3 ]; then echo yes; else echo no; fi
no

$ if [ 5 -eq 5 ]; then echo equal; fi
equal

$ if [ -z "" ]; then echo empty; fi
empty

$ if [ -n "hello" ]; then echo nonempty; fi
nonempty

## if-double-bracket
$ if [[ "hello" == "hello" ]]; then echo match; fi
match

$ if [[ 10 -gt 5 ]] && [[ 3 -lt 7 ]]; then echo yes; fi
yes

## for-in-list
$ for x in a b c; do echo $x; done
a
b
c

$ for x in 1 2 3; do echo "num: $x"; done
num: 1
num: 2
num: 3

## for-brace-expansion
$ for i in {1..5}; do echo $i; done
1
2
3
4
5

$ for c in {a..e}; do echo $c; done
a
b
c
d
e

## for-c-style
$ for ((i=0; i<5; i++)); do echo $i; done
0
1
2
3
4

$ for ((i=10; i>0; i-=3)); do echo $i; done
10
7
4
1

## while-loop
$ i=0; while [ $i -lt 5 ]; do echo $i; i=$((i + 1)); done
0
1
2
3
4

## until-loop
$ i=0; until [ $i -ge 3 ]; do echo $i; i=$((i + 1)); done
0
1
2

## case-statement
$ x=hello; case $x in hello) echo matched;; world) echo no;; esac
matched

$ x=test; case $x in a*) echo a;; t*) echo t;; esac
t

$ x=yes; case $x in y|yes) echo affirm;; n|no) echo deny;; esac
affirm

## break-and-continue
$ for i in 1 2 3 4 5; do if [ $i -eq 3 ]; then break; fi; echo $i; done
1
2

$ for i in 1 2 3 4 5; do if [ $i -eq 3 ]; then continue; fi; echo $i; done
1
2
4
5

## nested-loops
$ for i in 1 2; do for j in a b; do echo "$i$j"; done; done
1a
1b
2a
2b

## functions
$ greet() { echo "hello $1"; }; greet world
hello world

$ counter() { local x=0; x=$((x+1)); echo $x; }; counter; counter
1
1

## nested-if-in-loop
$ for i in 1 2 3; do if [ $i -eq 2 ]; then echo "found $i"; fi; done
found 2

## loop-with-command-sub
$ for f in $(echo "a b c"); do echo "item: $f"; done
item: a
item: b
item: c

## case-glob-patterns
$ x=file.tar.gz; case $x in *.gz) echo gzip;; *.bz2) echo bzip;; esac
gzip

$ for x in foo bar baz; do case $x in b*) echo "$x starts with b";; esac; done
bar starts with b
baz starts with b

## case-fallthrough
$ x=a; case $x in a) echo first;; b) echo second;; esac
first

$ x=5; case $x in [0-9]) echo digit;; *) echo other;; esac
digit

## subshell-exit-code
$ (true); echo $?
0

$ (false); echo $?
1

## command-grouping-redirect
$ { echo hello; echo world; } | cat
hello
world

$ { echo a; echo b; echo c; } | grep b
b

## pipeline-status
$ echo hello | grep hello > /dev/null; echo $?
0

$ echo hello | grep missing > /dev/null 2>&1; echo $?
1

## conditional-command-chain
$ x=5; [ $x -gt 3 ] && [ $x -lt 10 ] && echo "in range"
in range

$ x=15; [ $x -gt 3 ] && [ $x -lt 10 ] || echo "out of range"
out of range

## errexit-basic
$ set -e; true; echo "still here"
still here

## function-with-local
$ f() { local x=inside; echo $x; }; x=outside; f; echo $x
inside
outside

## function-return-code
$ succeed() { return 0; }; succeed; echo $?
0

$ fail() { return 1; }; fail; echo $?
1

$ get_code() { return 42; }; get_code; echo $?
42

## function-with-args
$ greet() { echo "Hello, $1!"; }; greet "World"
Hello, World!

$ repeat() { for i in $(seq $1); do echo "$2"; done; }; repeat 3 hi
hi
hi
hi

## nested-functions
$ outer() { inner() { echo "inner"; }; echo "outer"; inner; }; outer
outer
inner

## for-over-glob-like
$ for ext in txt log csv; do echo ".$ext"; done
.txt
.log
.csv

## subshell-exit-isolation
$ (exit 42); echo $?
42

$ (exit 0); echo "continued"
continued

## pipe-to-while-read
$ printf "a\nb\nc\n" | while read line; do echo "got: $line"; done
got: a
got: b
got: c

## pipe-to-brace-read
$ echo "hello" | { read word; echo "got: $word"; }
got: hello

$ echo "a b c" | { read x y z; echo "$x|$y|$z"; }
a|b|c

## double-bracket-string-compare
$ if [[ "abc" < "def" ]]; then echo yes; fi
yes

$ if [[ "def" > "abc" ]]; then echo yes; fi
yes

## redirect-to-dev-null
$ echo "visible"; echo "hidden" > /dev/null
visible

## test-command
$ test 5 -gt 3 && echo yes
yes

$ test -z "" && echo empty
empty

$ test -n "hello" && echo nonempty
nonempty

$ [ "abc" = "abc" ] && echo equal
equal

$ [ "abc" != "def" ] && echo notequal
notequal

## true-exit-code
$ true
[exit:0]
