## single-quotes
$ echo 'hello world'
hello world

$ echo '$not_a_variable'
$not_a_variable

$ echo 'no $(command) expansion'
no $(command) expansion

## single-quote-special-chars
$ echo 'pipe | here'
pipe | here

$ echo 'backslash \ here'
backslash \ here

$ echo '{braces} and (parens)'
{braces} and (parens)

$ echo 'a // b + c'
a // b + c

## double-quotes
$ x=world; echo "hello $x"
hello world

$ echo "two\nwords"
two\nwords

$ echo "$(echo embedded)"
embedded

## mixed-quoting
$ echo "it's a test"
it's a test

$ echo 'say "hello"'
say "hello"

$ echo "mix 'single' and \"double\""
mix 'single' and "double"

## empty-strings
$ echo ""

$ echo ''

## word-splitting
$ x="a b c"; for word in $x; do echo $word; done
a
b
c

$ x="a b c"; echo "$x"
a b c

## whitespace-preservation
$ echo "  spaces  "
  spaces

$ x="  hello  "; echo "$x"
  hello

$ x="a  b  c"; echo "$x"
a  b  c

$ x=$(echo "  spaces  "); echo ">$x<"
>  spaces  <

$ x=hello; x+=" world"; echo "$x"
hello world

## multiline-string-in-var
$ x=$(printf "hello\nworld"); echo "$x"
hello
world

## ansi-c-quoting-newline
$ echo $'hello\nworld'
hello
world

## ansi-c-quoting-tab
$ echo $'col1\tcol2'
col1	col2

## escape-sequences
$ echo "hello\"world"
hello"world

$ echo "back\\slash"
back\slash

$ echo "dollar\$sign"
dollar$sign
