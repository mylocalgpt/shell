## basic-file-ops
$ echo "hello" > /tmp/shelltest1; cat /tmp/shelltest1
hello

$ echo "line1" > /tmp/shelltest2; echo "line2" >> /tmp/shelltest2; cat /tmp/shelltest2
line1
line2

## redirect-stderr
$ echo "out"; echo "err" >&2
out

## dev-null
$ echo "gone" > /dev/null

$ cat /dev/null

## input-redirect
$ echo "from file" > /tmp/shelltest3; cat < /tmp/shelltest3
from file

## heredoc-with-vars
$ x=WORLD; cat <<EOF
HELLO $x
$((1+2)) items
$(echo nested)
EOF
HELLO WORLD
3 items
nested

## heredoc-quoted-no-expand
$ cat <<'END'
$HOME should not expand
$(echo nor this)
END
$HOME should not expand
$(echo nor this)

## heredoc-tabstrip
$ cat <<-EOF
	indented
	content
EOF
indented
content

## here-string-with-var
$ x=world; cat <<< "hello $x"
hello world

## multiple-redirects
$ echo "both" > /tmp/shelltest4 2>&1; cat /tmp/shelltest4
both

## pipe-to-file
$ echo -e "c\na\nb" | sort > /tmp/shelltest5; cat /tmp/shelltest5
a
b
c

## conditional-file-ops
$ echo "data" > /tmp/shelltest6; if [ -f /tmp/shelltest6 ]; then echo exists; fi
exists

$ if [ -f /tmp/nonexistent_file_xyz ]; then echo exists; else echo missing; fi
missing

## write-and-process
$ echo -e "3\n1\n2" > /tmp/shelltest7; sort -n /tmp/shelltest7
1
2
3

$ echo "hello world" > /tmp/shelltest8; wc -w < /tmp/shelltest8
(re)

## set-noclobber
$ echo first > /tmp/noclobber_test; set -C; { echo second > /tmp/noclobber_test; } 2>/dev/null; echo $?; cat /tmp/noclobber_test; set +C; rm -f /tmp/noclobber_test
1
first

## stderr-through-pipe
$ { echo "out"; echo "err" >&2; } 2>&1 | sort
err
out
