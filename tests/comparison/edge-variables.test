## nested-substitution
$ x=world; echo "hello $(echo $x)"
hello world

$ echo "$(echo "$(echo deep)")"
deep

$ x=abc; echo "${#x} chars"
3 chars

## empty-and-special
$ echo "${empty_var}"

$ echo "before${empty_var}after"
beforeafter

$ x=""; echo "[$x]"
[]

$ x=""; if [ -z "$x" ]; then echo empty; fi
empty

## default-chains
$ a=first; echo "${a:-${b:-fallback}}"
first

## expansion-in-assignment
$ x=$(echo hello); echo "$x"
hello

$ x="val_$(echo suffix)"; echo "$x"
val_suffix

$ x=5; y=$((x * 2)); echo $y
10

## special-chars-in-values
$ x='hello"world'; echo "$x"
hello"world

$ x="has'quote"; echo "$x"
has'quote

$ x='$not_expanded'; echo "$x"
$not_expanded

## variable-indirection
$ x=hello; y=x; echo ${!y}
hello

## readonly-var
$ readonly RO=42; echo $RO
42

## glob-strip-greedy
$ x=hello.tar.gz; echo ${x%%.*}
hello

$ x=/usr/local/bin; echo ${x##*/}
bin

## array-element-access
$ arr=(a b c); echo ${arr[0]}
a

## array-all-elements
$ arr=(a b c); echo ${arr[@]}
a b c

## array-length
$ arr=(a b c); echo ${#arr[@]}
3

## array-index-assign (xfail: arr[N]=val not recognized as assignment)
$ arr=(a b c); arr[1]=B; echo ${arr[@]}
a B c

## command-sub-in-replacement (xfail: command substitution in replacement is empty)
$ x=hello; echo "${x/hel/$(echo good)}"
goodlo

## brace-expansion-with-var (xfail: variable inside brace expansion not resolved)
$ x=3; echo {1..$x}
{1..3}

## ifs-and-word-splitting
$ x="a  b  c"; echo $x
a b c

